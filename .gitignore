# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ── Node (frontend abandonado) ──
node_modules/
dist/
.vite/

# ── Streamlit / caché local de la app ──
.streamlit/secrets.toml
.cache/
*.pkl
*.parquet

# ── Datos fuente (no versionar Excel fuera de data/) ──
*.xlsx
*.xls
~$*
# Excepción: la base de la nube en data/ SÍ se versiona.
# Se versiona el .parquet (carga rápida, poca RAM); el .xlsx NO se sube al repo
# (parsearlo en la nube dispara memoria y tumba el contenedor — usar el parquet).
!data/*.parquet

# ── Sistema operativo / editores ──
Thumbs.db
.DS_Store
.idea/
.vscode/
*.log
